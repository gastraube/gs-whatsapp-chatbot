{
  "ConnectionStrings": {
    "DefaultConnection": "Server=localhost;Database=gschatbot;User=root;Password=YOUR_PASSWORD"
  },
  "Twilio": {
    "AccountSid": "YOUR_TWILIO_ACCOUNT_SID",
    "AuthToken": "YOUR_TWILIO_AUTH_TOKEN",
    "PhoneNumber": "YOUR_TWILIO_PHONE_NUMBER"
  },
  "Ollama": {
    "Url": "http://localhost:11434",
    // Modelos disponíveis (trocar apenas o valor abaixo):
    //   mistral        — Mistral 7B (padrão original, segue menos instruções)
    //   qwen2.5:7b     — Qwen 2.5 7B (melhor seguimento de instruções, recomendado)
    //   llama3.2:3b    — Llama 3.2 3B (mais leve, menor qualidade)
    //   llama3.1:8b    — Llama 3.1 8B (bom equilíbrio)
    "Model": "qwen2.5:7b"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.EntityFrameworkCore": "Information"
    }
  },
  "AllowedHosts": "*"
}
